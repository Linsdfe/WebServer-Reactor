{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug WebServer",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/bin/server",
            "args": ["8888", "24", "localhost", "root", "123456", "webserver_db"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/bin",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug",
            "miDebuggerPath": "/usr/bin/gdb",
            // 新增：解决调试符号路径问题，加固断点绑定
            "sourceFileMap": {
                "/build/glibc-...": "/usr/src/debug/glibc"
            }
        }
    ]
}